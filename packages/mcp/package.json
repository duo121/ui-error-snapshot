{
  "name": "@duo121/ui-error-snapshot-mcp",
  "version": "0.1.3",
  "description": "MCP server for ui-error-snapshot — read/clear/probe dev UI crash files",
  "type": "module",
  "bin": {
    "ui-error-snapshot-mcp": "./bin/ui-error-snapshot-mcp.js"
  },
  "files": [
    "bin/ui-error-snapshot-mcp.js",
    "dist/server.js",
    "dist/server.d.ts",
    "dist/tools.js",
    "dist/tools.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/server.js bin/ui-error-snapshot-mcp.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@duo121/ui-error-snapshot-core": "0.1.0",
    "@duo121/ui-error-snapshot-sink-file": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.20.1",
    "zod": "^3.24.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duo121/ui-error-snapshot",
    "directory": "packages/mcp"
  }
}
